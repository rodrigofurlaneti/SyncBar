    Company {
        BIGINT Id PK
        NVARCHAR LegalName
        CHAR Cnpj
        BIT IsActive
    }
    Branch {
        BIGINT Id PK
        BIGINT CompanyId FK
        NVARCHAR Name
    }
    AppUser {
        BIGINT Id PK
        BIGINT CompanyId FK
        BIGINT EmployeeId FK
        VARCHAR UserName
        VARCHAR PasswordHash
    }
    Employee {
        BIGINT Id PK
        BIGINT BranchId FK
        BIGINT JobTitleId FK
        NVARCHAR Name
        CHAR Cpf
    }
    Product {
        BIGINT Id PK
        BIGINT CompanyId FK
        BIGINT CategoryId FK
        DECIMAL SalePrice
        BIT IsStockControlled
    }
    DiningTable {
        BIGINT Id PK
        BIGINT BranchId FK
        INT Number
        BIGINT TableStatusId FK
    }
    Comanda {
        BIGINT Id PK
        BIGINT BranchId FK
        VARCHAR Code
        BIGINT ComandaStatusId FK
    }
    CustomerOrder {
        BIGINT Id PK
        BIGINT DiningTableId FK
        BIGINT ComandaId FK
        BIGINT OrderStatusId FK
        DECIMAL TotalAmount
    }
    OrderItem {
        BIGINT Id PK
        BIGINT CustomerOrderId FK
        BIGINT ProductId FK
        DECIMAL Quantity
        DECIMAL TotalAmount
    }
    CashSession {
        BIGINT Id PK
        BIGINT CashRegisterId FK
        DECIMAL OpeningAmount
        DECIMAL ClosingAmount
    }
    Sale {
        BIGINT Id PK
        BIGINT CustomerOrderId FK
        BIGINT CashSessionId FK
        DECIMAL TotalAmount
    }
    SalePayment {
        BIGINT Id PK
        BIGINT SaleId FK
        BIGINT PaymentMethodId FK
        DECIMAL Amount
    }
    StockItem {
        BIGINT Id PK
        BIGINT BranchId FK
        BIGINT ProductId FK
        DECIMAL CurrentQuantity
    }
    StockMovement {
        BIGINT Id PK
        BIGINT StockItemId FK
        BIGINT StockMovementTypeId FK
        DECIMAL Quantity
    }
