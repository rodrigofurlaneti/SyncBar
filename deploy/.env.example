# ==========================================================================
# Variaveis de ambiente da SyncBar.API em producao.
#
# Na VM, copie este arquivo para /opt/syncbarservice/.env e preencha os
# valores reais. O deploy.yml sobe o container com --env-file apontando
# para esse caminho. NUNCA versione o .env real (apenas este .example).
#
#   sudo mkdir -p /opt/syncbarservice
#   sudo cp deploy/.env.example /opt/syncbarservice/.env
#   sudo nano /opt/syncbarservice/.env
# ==========================================================================

ASPNETCORE_ENVIRONMENT=Production

# String de conexao com o SQL Server (ajuste host/porta/senha do seu servidor).
# Use o host real do banco na VM (ex.: 127.0.0.1,1433 se o SQL roda na propria VM).
# OBS: a SyncBar.API NAO aplica migrations no startup — o schema do banco
# (BarRestauranteDb) deve ser criado/atualizado separadamente (scripts em /sql
# ou "dotnet ef database update") antes/depois do primeiro deploy.
ConnectionStrings__DefaultConnection=Server=127.0.0.1,1433;Database=BarRestauranteDb;User Id=sa;Password=DEFINA_A_SENHA_DO_SQL;TrustServerCertificate=True;

# Configuracao do JWT (mesmas chaves lidas do appsettings.json).
# IMPORTANTE: o secret precisa ter pelo menos 64 caracteres e NAO pode conter
# o texto "TROCAR" (a API bloqueia o startup se detectar o placeholder).
Jwt__Secret=DEFINA_UM_SEGREDO_LONGO_E_ALEATORIO_COM_64_CARACTERES_OU_MAIS
Jwt__Issuer=SyncBar
Jwt__Audience=SyncBar.Client

# Origem(ns) permitida(s) no CORS — normalmente a URL do frontend em producao.
Cors__AllowedOrigins__0=https://seu-frontend.exemplo.com
